    <fieldUpdates>
        <fullName>Converted_date</fullName>
        <field>Lead_Converted_date__c</field>
        <formula>TODAY()</formula>
        <name>Converted date</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>Fill_First_Lead_Status_Edit_with_Now</fullName>
        <field>First_Lead_Status_Edit__c</field>
        <formula>NOW()</formula>
        <name>Fill First Lead Status Edit with Now</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <rules>
        <fullName>Fill the first lead Status Edit Date</fullName>
        <actions>
            <name>Fill_First_Lead_Status_Edit_with_Now</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <formula>ISBLANK(First_Lead_Status_Edit__c) &amp;&amp; ISCHANGED(Status) &amp;&amp; ISPICKVAL(PRIORVALUE(Status), &quot;MQL&quot;)</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
</Workflow>
