<?xml version="1.0" encoding="UTF-8"?>
<Workflow xmlns="http://soap.sforce.com/2006/04/metadata">
    <alerts>
        <fullName>Closed_won_Support_Email_Alert</fullName>
        <ccEmails>customersupport@eficode.com</ccEmails>
        <description>Closed won Support Email Alert</description>
        <protected>false</protected>
        <senderAddress>licensing_uk@eficode.com</senderAddress>
        <senderType>OrgWideEmailAddress</senderType>
        <template>unfiled$public/New_Support_Contract_Alert_Email_internal</template>
    </alerts>
    <alerts>
        <fullName>New_Support_Contract_Alert_Email_internal</fullName>
        <ccEmails>customersupport@eficode.com</ccEmails>
        <description>New Support Contract Alert Email - internal2</description>
        <protected>false</protected>
        <senderAddress>licensing_uk@eficode.com</senderAddress>
        <senderType>OrgWideEmailAddress</senderType>
        <template>unfiled$public/New_Support_Contract_Alert_Email_internal</template>
    </alerts>
    <fieldUpdates>
        <fullName>Calculate_Editable_Cost_Price</fullName>
        <field>Editable_Cost_Price__c</field>
        <formula>CASE(CurrencyIsoCode, 
&apos;GBP&apos;,  Editable_Cost_Price_in_Dollars__c * Buying_ExchangeRate_USDtoGBP_on_creation__c, 
&apos;EUR&apos;, Editable_Cost_Price_in_Dollars__c * Buying_ExchangeRate_USDtoEUR_on_creation__c, 
Editable_Cost_Price_in_Dollars__c)</formula>
        <name>Calculate Editable Cost Price</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>Calculate_Unit_List_Price</fullName>
        <field>UnitPrice</field>
        <formula>CASE(CurrencyIsoCode, 
&apos;GBP&apos;, Editable_Unit_List_Price_in_USD__c * List_Exchange_Rate_from_USD_to_GBP__c,
&apos;EUR&apos;, Editable_Unit_List_Price_in_USD__c * List_Exchange_Rate_from_USD_to_EUR__c, 
Editable_Unit_List_Price_in_USD__c)</formula>
        <name>Calculate Unit List Price</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>Product_familly_from_product</fullName>
        <field>Product_Familly__c</field>
        <formula>TEXT(Product2.Family)</formula>
        <name>Product familly from product</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <rules>
        <fullName>Editable Cost Price Dollar</fullName>
        <actions>
            <name>Calculate_Editable_Cost_Price</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <formula>(ISNEW() || ISCHANGED(Editable_Cost_Price_in_Dollars__c)) &amp;&amp; NOT(ISBLANK(Editable_Cost_Price_in_Dollars__c))  &amp;&amp; (ISPICKVAL( Opportunity.Account.CV_Subsidiary__c , &quot;UK&quot;) || ISPICKVAL(Opportunity.Account.CV_Subsidiary__c  , &quot;US&quot;))</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>Editable Unit List Price In USD</fullName>
        <actions>
            <name>Calculate_Unit_List_Price</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <formula>(ISNEW() || ISCHANGED(Editable_Unit_List_Price_in_USD__c))  &amp;&amp; NOT(ISBLANK(Editable_Unit_List_Price_in_USD__c)) &amp;&amp;(ISPICKVAL( Opportunity.Account.CV_Subsidiary__c , &quot;UK&quot;) || ISPICKVAL(Opportunity.Account.CV_Subsidiary__c  , &quot;US&quot;))</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>Product familly</fullName>
        <actions>
            <name>Product_familly_from_product</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <criteriaItems>
            <field>OpportunityLineItem.CreatedDate</field>
            <operation>notEqual</operation>
        </criteriaItems>
        <description>This workflow will bring the product family from the product, (used mainly for roll ups and formulas)</description>
        <triggerType>onAllChanges</triggerType>
    </rules>
</Workflow>
