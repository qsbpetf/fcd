<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>61.0</apiVersion>
    <environments>Default</environments>
    <formulas>
        <name>TotalSalesPrice</name>
        <dataType>Currency</dataType>
        <expression>IF(ISBLANK( {!$Record.Discount__c} ), 

{!$Record.List_Price_Inc_Licence_Type__c}, {!$Record.List_Price_Inc_Licence_Type__c} - ({!$Record.List_Price_Inc_Licence_Type__c}  *  ({!$Record.Discount__c}*100)))</expression>
        <scale>2</scale>
    </formulas>
    <interviewLabel>Quote Sync &gt; Opp Product to Quote Product when Opp Product is updated {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Quote Sync &gt; Opp Product to Quote Product when Opp Product is updated</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Update_Quote_Line_Item</name>
        <label>Update Quote Line Item</label>
        <locationX>176</locationX>
        <locationY>323</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>OpportunityLineItemId</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </filters>
        <filters>
            <field>QuoteId</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Opportunity.SyncedQuote.Id</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>Additional_Info__c</field>
            <value>
                <elementReference>$Record.Additional_Info__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Cloud_Site_Name__c</field>
            <value>
                <elementReference>$Record.Cloud_Site_Name__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Discount__c</field>
            <value>
                <elementReference>$Record.Discount__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Entitlement_Number__c</field>
            <value>
                <elementReference>$Record.Entitlement_Number__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Licence_End_Date__c</field>
            <value>
                <elementReference>$Record.License_end_date__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Licence_Start_Date__c</field>
            <value>
                <elementReference>$Record.License_Start_date__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Quantity</field>
            <value>
                <elementReference>$Record.Quantity</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Renewal__c</field>
            <value>
                <elementReference>$Record.Renewal__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>SEN__c</field>
            <value>
                <elementReference>$Record.SEN__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>UnitPrice</field>
            <value>
                <elementReference>$Record.UnitPrice</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Unusual_discount_reviewed__c</field>
            <value>
                <elementReference>$Record.Unusual_discount_reviewed__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>User_Count__c</field>
            <value>
                <elementReference>$Record.User_Count__c</elementReference>
            </value>
        </inputAssignments>
        <object>QuoteLineItem</object>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Update_Quote_Line_Item</targetReference>
        </connector>
        <filterFormula>{!$Setup.AutomationSettings__c.Automation_Enabled__c} = True &amp;&amp;
NOT(ISBLANK({!$Record.Opportunity.SyncedQuoteId}))</filterFormula>
        <object>OpportunityLineItem</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Draft</status>
</Flow>
