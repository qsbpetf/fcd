    <decisions>
        <name>myRule_8</name>
        <label>Product for renewal</label>
        <locationX>248</locationX>
        <locationY>323</locationY>
        <defaultConnector>
            <targetReference>myRule_10</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>FALSE_Product for renewal</defaultConnectorLabel>
        <rules>
            <name>TRUE_myRule_8</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>LIC_or_MS_to_renew</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>myRule_8_A1</targetReference>
            </connector>
            <label>TRUE_Product for renewal</label>
        </rules>
    </decisions>
    <description>Check or uncheck the field &quot;Product for renewal&quot; based on type and product family</description>
    <environments>Default</environments>
    <formulas>
        <name>LIC_or_MS_NOT_to_renew</name>
        <dataType>Boolean</dataType>
        <expression>NOT(
AND(ISPICKVAL({!$Record.Renewal__c} , &quot;Renewal (CV Owned)&quot;) ,

OR(
CONTAINS(TEXT({!$Record.PricebookEntry.Product2.Family}) ,&quot;LIC:&quot;),
CONTAINS(TEXT({!$Record.PricebookEntry.Product2.Family}) ,&quot;MS:&quot;)))


)</expression>
    </formulas>
    <formulas>
        <name>LIC_or_MS_to_renew</name>
        <dataType>Boolean</dataType>
        <expression>AND(



OR(			
ISPICKVAL({!$Record.Renewal__c} , &quot;Renewal (CV Owned)&quot;) ,			
ISPICKVAL({!$Record.Renewal__c} , &quot;Renewal (New to CV)&quot;) ,			
ISPICKVAL({!$Record.Renewal__c} , &quot;Upgrade (Same Platform)&quot;) ,			
ISPICKVAL({!$Record.Renewal__c} , &quot;Upgrade (Server to DC)&quot;) ,			
ISPICKVAL({!$Record.Renewal__c} , &quot;Upgrade (Server to Cloud)&quot;) ,			
ISPICKVAL({!$Record.Renewal__c} , &quot;Upgrade (DC to Cloud)&quot;) ,			
ISPICKVAL({!$Record.Renewal__c} , &quot;Downgrade (Same Platform)&quot;) ,			
ISPICKVAL({!$Record.Renewal__c} , &quot;Cloud Monthly to Annual&quot;) ,			
ISPICKVAL({!$Record.Renewal__c} , &quot;Cloud Annual to Monthly&quot;)) ,			

OR(
CONTAINS(TEXT({!$Record.PricebookEntry.Product2.Family}) ,&quot;LIC:&quot;),
CONTAINS(TEXT({!$Record.PricebookEntry.Product2.Family}) ,&quot;MS:&quot;)))</expression>
    </formulas>
    <interviewLabel>Product for renewal {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Product for renewal</label>
