    <description>When the T1 Start Date on account is set or changed, this flow sets T1 Opp = &apos;Yes&quot; on all related opps allowed to be modified if the close date is &gt;= to the T1 Start Date</description>
    <environments>Default</environments>
    <formulas>
        <name>X90daysago</name>
        <dataType>Date</dataType>
        <expression>TODAY() -90</expression>
    </formulas>
    <interviewLabel>T1 Opp = Yes from Account {!$Flow.CurrentDateTime}</interviewLabel>
    <label>T1 Opp = Yes from Account</label>
