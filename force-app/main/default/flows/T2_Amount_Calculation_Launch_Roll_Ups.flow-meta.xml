    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Revenue_Type</targetReference>
        </connector>
        <filterFormula>{!$Setup.AutomationSettings__c.Automation_Enabled__c}= true &amp;&amp; 
{!$Record.Opportunity.Quota_Update_Allowed__c} = true &amp;&amp; 
(ISPICKVAL({!$Record.Opportunity.Account.CV_Subsidiary__c}, &quot;UK&quot;) || ISPICKVAL({!$Record.Opportunity.Account.CV_Subsidiary__c}, &quot;US&quot;)) &amp;&amp;
(ISNEW() ||
ISCHANGED({!$Record.PricebookEntry.Product2.Revenue_Type__c} )||
