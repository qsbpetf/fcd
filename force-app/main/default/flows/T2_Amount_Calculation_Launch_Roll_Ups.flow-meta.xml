ISCHANGED({!$Record.Editable_Cost_Price__c})||
ISCHANGED({!$Record.Editable_Cost_Price_in_Dollars__c})||
ISCHANGED({!$Record.Total_Buy_Price_Incl_Discount__c})||
ISCHANGED({!$Record.Unit_Buy_Price__c})
)</filterFormula>
        <object>OpportunityLineItem</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
