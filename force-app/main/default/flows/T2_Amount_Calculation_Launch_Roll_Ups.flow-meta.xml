    <description>This flow calculates the T2 Attainment amount on opportunity product when a product is added or edited and one of field affecting the Total Price or Margin is changed</description>
    <environments>Default</environments>
    <formulas>
        <name>ProjectStartDate365</name>
        <dataType>Date</dataType>
        <expression>{!$Record.Opportunity.Project_Start_Date_From_Project__c} + 365</expression>
    </formulas>
    <formulas>
        <name>T2Amount</name>
        <dataType>Currency</dataType>
        <expression>IF(ISNULL({!$Record.Opportunity.Related_Project__c}),  {!$Record.Total_List_Price_Incl_Discount__c} , 
IF(({!$Record.Revenue_Type_Formula__c} = &quot;Consulting&quot; || {!$Record.Revenue_Type_Formula__c} = &quot;Managed Services&quot;) , 
   0, 
IF((ISPICKVAL({!$Record.Renewal__c}, &quot;New&quot;) || ISPICKVAL({!$Record.Renewal__c}, &quot;Renewal (CV Owned)&quot;)), 
    {!$Record.Total_List_Price_Incl_Discount__c} , 

IF({!$Record.Opportunity.Project_Start_Date_From_Project__c} + 365 &lt; {!$Record.License_Start_date__c} , 
   0, 

IF({!$Record.License_end_date__c} &lt; {!$Record.Opportunity.Project_Start_Date_From_Project__c} + 365  , 
    {!$Record.Total_List_Price_Incl_Discount__c} , 

((({!$Record.Opportunity.Project_Start_Date_From_Project__c}  + 365 -  {!$Record.License_Start_date__c} ) / {!$Record.days__c}) * 
  {!$Record.Total_List_Price_Incl_Discount__c})
)))))</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>T2Calculation</name>
        <dataType>Currency</dataType>
        <expression>((({!$Record.Opportunity.Project_Start_Date_From_Project__c}  + 365 -  {!$Record.License_Start_date__c} ) / {!$Record.days__c}) * 
  {!$Record.Total_List_Price_Incl_Discount__c})</expression>
        <scale>2</scale>
    </formulas>
    <interviewLabel>T2 Amount Calculation + Launch Roll Ups {!$Flow.CurrentDateTime}</interviewLabel>
    <label>T2 Amount Calculation</label>
    <processMetadataValues>
        <name>BuilderType</name>
