    <description>Migrated from the Quote updates (Creation) process using multiple criteria.
Fire any automation on Quote Creation</description>
    <environments>Default</environments>
    <formulas>
        <name>ExpringDateFormula</name>
        <dataType>Date</dataType>
        <expression>IF(


OR({!$Record.Opportunity.AT_quote_expiry_formula__c} &gt; TODAY() + 30 , ISBLANK({!$Record.Opportunity.AT_quote_expiry_formula__c})),



DATEVALUE({!$Record.CreatedDate}) + 30 , {!$Record.Opportunity.AT_quote_expiry_formula__c})</expression>
    </formulas>
