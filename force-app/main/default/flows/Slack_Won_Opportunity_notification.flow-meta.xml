        <name>Which_notifications_to_send</name>
        <label>Which notifications to send?</label>
        <locationX>484</locationX>
        <locationY>984</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Send_won_deal_notifications</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.StageName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Closed won - awaiting approval</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>NetRevenueInCorporate</leftValueReference>
                <operator>GreaterThanOrEqualTo</operator>
                <rightValue>
                    <numberValue>3000.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Send_opportunity_won_notification</targetReference>
            </connector>
            <label>Send won deal notifications</label>
        </rules>
        <rules>
            <name>Send_sales_support_notification</name>
            <conditionLogic>1 AND 2 AND (3 OR 4)</conditionLogic>
            <conditions>
                <leftValueReference>$Record.StageName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Identify Needs</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Delivery_Owner__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Estimate_Consulting_Revenue__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Revenue_Types_Declarative__c</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>Consulting</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Send_consultancy_support_notification</targetReference>
            </connector>
            <label>Send sales support notification</label>
        </rules>
    </decisions>
    <description>Automation Enabled checking added //Ceili: Atte 7.5.-24</description>
    <environments>Default</environments>
    <formulas>
        <name>NetRevenueInCorporate</name>
        <dataType>Number</dataType>
        <expression>{!$Record.Net_Revenue__c} / CURRENCYRATE(TEXT({!$Record.CurrencyIsoCode}))</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>TotalAmountInCorporate</name>
        <dataType>Number</dataType>
        <expression>{!$Record.Total_Amount__c} / CURRENCYRATE(TEXT({!$Record.CurrencyIsoCode}))</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <description>Total amount in DKK, used to check if #denmark notification should be sent.</description>
        <name>TotalAmountInDKK</name>
        <dataType>Number</dataType>
        <expression>IF(
TEXT({!$Record.CurrencyIsoCode}) = &quot;DKK&quot;,
{!$Record.Total_Amount__c},
{!$Record.Total_Amount__c} / CURRENCYRATE(TEXT({!$Record.CurrencyIsoCode})) * CURRENCYRATE(&quot;DKK&quot;)
)</expression>
        <scale>0</scale>
    </formulas>
