    <description>Updated field information to Opportunity when stage changed to Closed Won - Awaiting Approval and Subsidiary is US or UK // Iida 5.3.2024, Automation enabled check added // Atte 7.5.-24</description>
    <environments>Default</environments>
    <formulas>
        <name>forConsultantsAllocated</name>
        <dataType>String</dataType>
        <expression>IF(ISBLANK({!$Record.Consultant_s_Allocated__c}), &quot;NA&quot;, {!$Record.Consultant_s_Allocated__c})</expression>
    </formulas>
    <formulas>
        <name>forContact</name>
        <dataType>String</dataType>
        <expression>IF(ISBLANK({!$Record.Delivery_Owner__c}),{!Get_Joe_s_Contact.Id},{!$Record.Delivery_Owner__c})</expression>
    </formulas>
    <formulas>
        <name>forFixedPrice</name>
        <dataType>Number</dataType>
        <expression>IF(ISBLANK({!$Record.Fixed_Price_Hours_Estimate__c}),1,{!$Record.Fixed_Price_Hours_Estimate__c})</expression>
        <scale>1</scale>
    </formulas>
    <formulas>
        <name>forNewOrExtension</name>
        <dataType>String</dataType>
        <expression>IF(ISBLANK(TEXT({!$Record.New_or_Extension__c})), &quot;New (New Project required in NS)&quot;,TEXT({!$Record.New_or_Extension__c}))</expression>
    </formulas>
    <formulas>
        <name>forProjectType</name>
        <dataType>String</dataType>
        <expression>IF(ISBLANK(TEXT({!$Record.Project_Type__c})), &quot;Fixed Price&quot;,TEXT({!$Record.Project_Type__c}))</expression>
    </formulas>
    <formulas>
        <name>forStartDate</name>
        <dataType>Date</dataType>
        <expression>IF(ISBLANK({!$Record.Project_Start_Date__c}),{!$Record.CloseDate},{!$Record.Project_Start_Date__c})</expression>
    </formulas>
    <formulas>
        <name>varURL</name>
        <dataType>String</dataType>
        <expression>IF(ISBLANK({!$Record.Contract_Drive_Folder_url__c}), &quot;www.eficode.com&quot;, {!$Record.Contract_Drive_Folder_url__c})</expression>
    </formulas>
