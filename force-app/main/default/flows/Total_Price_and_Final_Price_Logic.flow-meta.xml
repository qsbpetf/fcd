<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>58.0</apiVersion>
    <decisions>
        <name>Has_Discount</name>
        <label>Has Discount</label>
        <locationX>182</locationX>
        <locationY>431</locationY>
        <defaultConnector>
            <targetReference>myRule_5_A1</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Yes_Discount</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Discount__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>myRule_1_A2</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
        <name>TotalPrice</name>
        <dataType>Currency</dataType>
        <expression>{!$Record.Quantity} * {!$Record.UnitPrice}</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>TotalSalesPrice</name>
        <dataType>Currency</dataType>
        <expression>{!$Record.Total_Price__c} - (   {!$Record.Total_Price__c}*   ({!$Record.Discount__c}/100))</expression>
        <scale>2</scale>
    </formulas>
    <interviewLabel>Total Price and Final Price Logic {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Total Price and Final Price Logic</label>
    <processMetadataValues>
        <name>BuilderType</name>
