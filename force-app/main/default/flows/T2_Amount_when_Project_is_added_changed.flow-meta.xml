<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <description>This flow launched the autolaunched flow &quot;Calculate T2 Amount + Roll Up from Opportunity&quot; when the project is changed.</description>
    <environments>Default</environments>
    <interviewLabel>T2 Amount when Project is added/changed {!$Flow.CurrentDateTime}</interviewLabel>
    <label>T2 Amount when Project is added/changed</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Calculate_T2_Amount_Roll_Up_from_Opportunity</targetReference>
        </connector>
        <filterFormula>{!$Setup.AutomationSettings__c.Automation_Enabled__c}= true &amp;&amp;
(ISPICKVAL({!$Record.Account.CV_Subsidiary__c}, &quot;UK&quot;) || ISPICKVAL({!$Record.Account.CV_Subsidiary__c}, &quot;US&quot;)) &amp;&amp; 
{!$Record.Quota_Update_Allowed__c} = true  &amp;&amp;
ISCHANGED({!$Record.Related_Project__c}) &amp;&amp;
NOT(ISNULL({!$Record.Related_Project__c}))</filterFormula>
        <object>Opportunity</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <subflows>
        <name>Calculate_T2_Amount_Roll_Up_from_Opportunity</name>
        <label>Calculate T2 Amount + Roll Up from Opportunity</label>
        <locationX>176</locationX>
        <locationY>323</locationY>
        <flowName>Calculate_T2_Amount_Roll_Up_from_Opportunity</flowName>
        <inputAssignments>
            <name>OpportunityID</name>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <name>ProjectId</name>
            <value>
                <elementReference>$Record.Related_Project__r.Id</elementReference>
            </value>
        </inputAssignments>
    </subflows>
</Flow>
