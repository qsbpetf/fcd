    <description>Assign the correct type depending on Account type and last order date</description>
    <environments>Default</environments>
    <formulas>
        <name>formula_TRUE_myRule_10</name>
        <dataType>Boolean</dataType>
        <expression>ISPICKVAL({!$Record.Account.Type} ,&quot;Customer&quot;)

 &amp;&amp;
NOT(ISPICKVAL({!$Record.Type} , &quot;MDF&quot;))
&amp;&amp;
NOT(ISPICKVAL({!$Record.Type} , &quot;Intercompany&quot;))

&amp;&amp;
({!$Record.Account.Last_Order_Date_Final_Formula_Field__c}  + 730 &lt;=  TODAY() || ISBLANK({!$Record.Account.Last_Order_Date_Final_Formula_Field__c}))</expression>
    </formulas>
    <formulas>
        <name>formula_TRUE_myRule_12</name>
        <dataType>Boolean</dataType>
        <expression>(ISPICKVAL({!$Record.Account.Type} ,&quot;Customer&quot;) 

&amp;&amp;

NOT(ISPICKVAL({!$Record.Type} , &quot;Customer Opp - NEW Division&quot;))
 &amp;&amp;
NOT(ISPICKVAL({!$Record.Type} , &quot;MDF&quot;))
&amp;&amp;
NOT(ISPICKVAL({!$Record.Type} , &quot;Intercompany&quot;))

&amp;&amp;
{!$Record.Account.Last_Order_Date_Final_Formula_Field__c} + 730 &gt; TODAY() )

|| 

(ISPICKVAL({!$Record.Account.Type} ,&quot;Reseller&quot;) 

&amp;&amp;

NOT(ISPICKVAL({!$Record.Type} , &quot;Customer Opp - NEW Division&quot;))
 &amp;&amp;
NOT(ISPICKVAL({!$Record.Type} , &quot;MDF&quot;))
&amp;&amp;
NOT(ISPICKVAL({!$Record.Type} , &quot;Intercompany&quot;)))</expression>
    </formulas>
