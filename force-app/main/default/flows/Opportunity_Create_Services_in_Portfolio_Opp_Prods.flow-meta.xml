                <rightValue>
                    <elementReference>$Record__Prior.Trigger_Sync__c</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>If_varServicesInPortfolio_Not_Blank</targetReference>
            </connector>
            <label>Is_New_or_Trigger_Sync</label>
        </rules>
    </decisions>
