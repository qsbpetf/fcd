    <decisions>
        <name>Is_above_45k_for_Scandinavia</name>
        <label>Is above 45k for Scandinavia ?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Yes</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>IsAbove45kEUR_Scandinavia</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Send_Slack_Message_to_Scandinavia_Channel</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <description>When an Opportunity is updated to Closed Won and Net Revenue exceeds 45k, Salesforce sends an Opportunity notification to the Scandinavia Slack channel.</description>
    <environments>Default</environments>
    <formulas>
        <name>IsAbove45kEUR_Scandinavia</name>
        <dataType>Boolean</dataType>
        <expression>AND(
  OR(
    TEXT({!$Record.CurrencyIsoCode}) = &quot;DKK&quot;,
    TEXT({!$Record.CurrencyIsoCode}) = &quot;SEK&quot;,
    TEXT({!$Record.CurrencyIsoCode}) = &quot;NOK&quot;
  ),
  (
    BLANKVALUE({!$Record.Net_Revenue__c}, 0) / 
    CURRENCYRATE(TEXT({!$Record.CurrencyIsoCode}))
  ) &gt; 45000
)</expression>
    </formulas>
    <interviewLabel>Send Slack Message to Scandinavia Slack Channel {!$Flow.CurrentDateTime}</interviewLabel>
