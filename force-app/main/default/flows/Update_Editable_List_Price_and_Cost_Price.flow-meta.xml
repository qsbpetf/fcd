        </connector>
        <filterFormula>({!$Setup.AutomationSettings__c.Automation_Enabled__c} = true ||
{!$Setup.AutomationSettings__c.Automation_Enabled_for_Import__c} = true ) &amp;&amp;
(ISNEW() 
||
(NOT(ISBLANK({!$Record.Editable_Cost_Price_in_Dollars__c})) &amp;&amp;
ISCHANGED({!$Record.Editable_Cost_Price_in_Dollars__c}))
||
(NOT(ISBLANK({!$Record.Editable_Unit_List_Price_in_USD__c})) &amp;&amp;
ISCHANGED({!$Record.Editable_Unit_List_Price_in_USD__c}))
