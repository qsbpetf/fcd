        <locationX>968</locationX>
        <locationY>539</locationY>
        <customErrorMessages>
            <errorMessage>Please review discount - we cannot give a discount if we are not making a margin on this product. Check &apos;unusual discount reviewed&apos; if you are confident this is correct.</errorMessage>
            <isFieldError>false</isFieldError>
        </customErrorMessages>
    </customErrors>
    <decisions>
        <name>Check_Error_Message</name>
        <label>Check Error Message</label>
        <locationX>1100</locationX>
        <locationY>431</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Discount</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Flow.FaultMessage</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>Please review discount - we cannot give a discount</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>DiscountErrorMessage</targetReference>
            </connector>
            <label>Discount</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
        <name>EditableCostPrice</name>
        <dataType>Currency</dataType>
        <expression>IF(ISPICKVAL({!$Record.CurrencyIsoCode}, &quot;USD&quot;), {!$Record.Editable_Cost_Price_in_Dollars__c}, 
 {!$Record.Editable_Cost_Price_in_Dollars__c} * {!$Record.Exchange_Rate__c})</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>UNITPRICE</name>
        <dataType>Currency</dataType>
        <expression>IF(ISPICKVAL({!$Record.CurrencyIsoCode}, &quot;USD&quot;), {!$Record.Editable_Unit_List_Price_in_USD__c} , 
 {!$Record.Editable_Unit_List_Price_in_USD__c} * {!$Record.Exchange_Rate__c})</expression>
        <scale>2</scale>
    </formulas>
