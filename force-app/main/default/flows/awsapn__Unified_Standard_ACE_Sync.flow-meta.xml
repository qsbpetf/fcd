        </inputAssignments>
        <inputAssignments>
            <field>awsapn__Target_Close_Date__c</field>
            <value>
                <elementReference>$Record.CloseDate</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>awsapn__Use_Case__c</field>
            <value>
                <stringValue>Training</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>awsapn__Visibility__c</field>
            <value>
                <stringValue>Full</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>awsapn__awsProducts__c</field>
            <value>
                <stringValue>AWSBatch</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>awsapn__opportunityType__c</field>
            <value>
                <stringValue>Net New Business</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>awsapn__salesActivities__c</field>
            <value>
                <stringValue>Initialized discussions with customer</stringValue>
            </value>
        </inputAssignments>
        <object>awsapn__ACE_Opportunity__c</object>
    </recordCreates>
    <recordLookups>
        <name>Check_Existing_ACE</name>
        <label>Check Existing ACE</label>
        <locationX>176</locationX>
        <locationY>200</locationY>
        <assignNullValuesIfNoRecordsFound>true</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Check_If_ACE_Exists</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>awsapn__Source_Opportunity__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </filters>
        <object>awsapn__ACE_Opportunity__c</object>
        <outputReference>varExistingACE</outputReference>
        <queriedFields>Id</queriedFields>
    </recordLookups>
    <recordLookups>
        <name>Get_Account_Details</name>
        <label>Get Account Details</label>
        <locationX>176</locationX>
        <locationY>400</locationY>
        <assignNullValuesIfNoRecordsFound>true</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Create_ACE_Opportunity</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.AccountId</elementReference>
            </value>
        </filters>
        <object>Account</object>
        <outputReference>varAccount</outputReference>
        <queriedFields>BillingCountry</queriedFields>
        <queriedFields>BillingState</queriedFields>
        <queriedFields>BillingPostalCode</queriedFields>
        <queriedFields>Website</queriedFields>
    </recordLookups>
    <recordUpdates>
        <name>Update_Existing_ACE</name>
        <label>Update Existing ACE</label>
        <locationX>400</locationX>
        <locationY>300</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>varExistingACE.Id</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>awsapn__Expected_Monthly_AWS_Revenue__c</field>
            <value>
                <elementReference>$Record.ExpectedRevenue</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>awsapn__Next_Step__c</field>
            <value>
                <elementReference>$Record.NextStep</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>awsapn__Stage__c</field>
            <value>
                <elementReference>MapStage</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>awsapn__Target_Close_Date__c</field>
            <value>
                <elementReference>$Record.CloseDate</elementReference>
            </value>
        </inputAssignments>
        <object>awsapn__ACE_Opportunity__c</object>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Check_Existing_ACE</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Description</field>
            <operator>Contains</operator>
            <value>
                <stringValue>Create ACE</stringValue>
            </value>
        </filters>
        <object>Opportunity</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Draft</status>
    <variables>
        <name>varAccount</name>
        <dataType>SObject</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <objectType>Account</objectType>
    </variables>
    <variables>
        <name>varExistingACE</name>
        <dataType>SObject</dataType>
        <isCollection>false</isCollection>
        <isInput>false</isInput>
        <isOutput>false</isOutput>
        <objectType>awsapn__ACE_Opportunity__c</objectType>
    </variables>
</Flow>
