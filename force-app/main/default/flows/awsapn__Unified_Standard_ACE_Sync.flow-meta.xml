<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>57.0</apiVersion>
    <decisions>
        <name>Check_If_ACE_Exists</name>
        <label>Check If ACE Exists</label>
        <locationX>176</locationX>
        <locationY>300</locationY>
        <defaultConnector>
            <targetReference>Get_Account_Details</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Create New ACE</defaultConnectorLabel>
        <rules>
            <name>ACE_Already_Exists</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>varExistingACE.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Existing_ACE</targetReference>
            </connector>
            <label>ACE Already Exists</label>
        </rules>
    </decisions>
    <description>Unified flow to sync Standard and ACE opportunities using only standard fields</description>
    <environments>Default</environments>
    <formulas>
        <name>MapStage</name>
        <dataType>String</dataType>
        <expression>CASE(
            {!$Record.StageName},
            &quot;Prospecting&quot;, &quot;Prospect&quot;,
            &quot;Qualification&quot;, &quot;Prospect&quot;,
            &quot;Needs Analysis&quot;, &quot;Qualified&quot;,
            &quot;Value Proposition&quot;, &quot;Technical Validation&quot;,
            &quot;Id. Decision Makers&quot;, &quot;Technical Validation&quot;,
            &quot;Perception Analysis&quot;, &quot;Business Validation&quot;,
            &quot;Proposal/Price Quote&quot;, &quot;Business Validation&quot;,
            &quot;Negotiation/Review&quot;, &quot;Committed&quot;,
            &quot;Closed Won&quot;, &quot;Launched&quot;,
            &quot;Closed Lost&quot;, &quot;Closed Lost&quot;,
            &quot;Prospect&quot;
        )</expression>
    </formulas>
    <formulas>
        <name>MapStateValue</name>
        <dataType>String</dataType>
        <expression>IF(
            AND(
                NOT(ISBLANK({!varAccount.BillingState})),
                OR(
                    {!varAccount.BillingCountry} = &quot;United States&quot;,
                    {!varAccount.BillingCountry} = &quot;US&quot;,
                    {!varAccount.BillingCountry} = &quot;USA&quot;
                )
            ),
            CASE({!varAccount.BillingState},
                &quot;AL&quot;, &quot;Alabama&quot;,
                &quot;AK&quot;, &quot;Alaska&quot;,
                &quot;AZ&quot;, &quot;Arizona&quot;,
                &quot;AR&quot;, &quot;Arkansas&quot;,
                &quot;CA&quot;, &quot;California&quot;,
                &quot;CO&quot;, &quot;Colorado&quot;,
                &quot;CT&quot;, &quot;Connecticut&quot;,
                &quot;DE&quot;, &quot;Delaware&quot;,
                &quot;FL&quot;, &quot;Florida&quot;,
                &quot;GA&quot;, &quot;Georgia&quot;,
