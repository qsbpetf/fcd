    <start>
        <locationX>56</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>myRule_1</targetReference>
        </connector>
        <filterFormula>{!$Setup.AutomationSettings__c.Automation_Enabled__c} = true &amp;&amp;
OR(
 ISPICKVAL( {!$Record.Opportunity.Account.CV_Subsidiary__c},&quot;UK&quot;),
 ISPICKVAL( {!$Record.Opportunity.Account.CV_Subsidiary__c},&quot;US&quot;))</filterFormula>
        <object>OpportunityLineItem</object>
