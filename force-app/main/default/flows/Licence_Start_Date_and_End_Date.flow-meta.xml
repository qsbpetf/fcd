        <locationY>323</locationY>
        <defaultConnector>
            <targetReference>myRule_6_A1</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>FALSE_Product familly</defaultConnectorLabel>
        <rules>
            <name>TRUE_myRule_1</name>
            <conditionLogic>1 AND (2 OR 3) AND 4</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Product2Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Product2.Family</leftValueReference>
                <operator>StartsWith</operator>
                <rightValue>
                    <elementReference>LIC</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Product2.Family</leftValueReference>
                <operator>StartsWith</operator>
                <rightValue>
                    <elementReference>MS</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Opportunity.Large_Duplicates__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>myRule_1_A1</targetReference>
            </connector>
            <label>TRUE_Product familly</label>
        </rules>
    </decisions>
    <description>Version 12022024 Jasmin/Ceili: Added entry condition to only trigger when Eficode Subsidiary is UK or US.</description>
    <environments>Default</environments>
    <formulas>
        <name>LIC</name>
        <dataType>String</dataType>
        <expression>&quot;LIC:&quot;</expression>
    </formulas>
    <formulas>
        <name>MS</name>
        <dataType>String</dataType>
        <expression>&quot;MS:&quot;</expression>
    </formulas>
    <formulas>
        <name>One_year_from_start_date</name>
        <dataType>Date</dataType>
        <expression>DATE(YEAR({!$Record.License_Start_date__c}  ) + 1,MONTH({!$Record.License_Start_date__c}),DAY({!$Record.License_Start_date__c}))</expression>
    </formulas>
    <formulas>
        <name>TODAY</name>
        <dataType>Date</dataType>
        <expression>TODAY()</expression>
    </formulas>
    <interviewLabel>Licence Start Date and End Date {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Licence Start Date and End Date</label>
    <processMetadataValues>
