<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Lock_Shipping_Address</fullName>
    <active>true</active>
    <errorConditionFormula>(Lock_Shipping_Address__c = true  &amp;&amp; 
 ISCHANGED(ShippingAddress)) &amp;&amp; $Setup.rh2__PS_Settings__c.rh2__Run_Validation_Rule__c</errorConditionFormula>
    <errorDisplayField>ShippingCountry</errorDisplayField>
    <errorMessage>The shipping address has been locked - Please contact an admin</errorMessage>
</ValidationRule>
