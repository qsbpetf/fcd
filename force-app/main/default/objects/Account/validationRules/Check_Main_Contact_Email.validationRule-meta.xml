<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Check_Main_Contact_Email</fullName>
    <active>false</active>
    <errorConditionFormula>AND(
    MS_Client__c = TRUE,
    ISBLANK(Main_Contact_Email__c)
)</errorConditionFormula>
    <errorMessage>The Main Contact’s email address is required. Please provide it before saving.</errorMessage>
</ValidationRule>
