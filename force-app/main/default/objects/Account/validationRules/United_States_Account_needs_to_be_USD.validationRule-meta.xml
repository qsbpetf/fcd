<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>United_States_Account_needs_to_be_USD</fullName>
    <active>true</active>
    <errorConditionFormula>($Setup.AutomationSettings__c.Validation_Rule_Enabled__c = True  &amp;&amp;
(ISPICKVAL(CV_Subsidiary__c, &quot;UK&quot;) || ISPICKVAL(CV_Subsidiary__c, &quot;US&quot;)) &amp;&amp;
Nb_of_won_opps__c &gt;= 1&amp;&amp;
(BillingCountry=&apos;United States&apos; &amp;&amp;  NOT(ISPICKVAL(CurrencyIsoCode, &apos;USD&apos;)))) &amp;&amp; $Setup.rh2__PS_Settings__c.rh2__Run_Validation_Rule__c</errorConditionFormula>
    <errorDisplayField>CurrencyIsoCode</errorDisplayField>
    <errorMessage>Account currency must be set to USD for US customers</errorMessage>
</ValidationRule>
