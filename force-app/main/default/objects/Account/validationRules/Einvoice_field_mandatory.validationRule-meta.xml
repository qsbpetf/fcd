<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Einvoice_field_mandatory</fullName>
    <active>false</active>
    <description>If the E-invoice fields are empty, an error message will be displayed.</description>
    <errorConditionFormula>(AND(
  ISBLANK(E_invoice_Address__c),
  NOT(ISBLANK(E_invoice_Operator_ID__c))
) 
||
AND(
  NOT(ISBLANK(E_invoice_Address__c)),
  ISBLANK(E_invoice_Operator_ID__c)
)
&amp;&amp; $Setup.rh2__PS_Settings__c.rh2__Run_Validation_Rule__c) &amp;&amp; $Setup.rh2__PS_Settings__c.rh2__Run_Validation_Rule__c</errorConditionFormula>
    <errorMessage>You must complete  E-invoice fields</errorMessage>
</ValidationRule>
