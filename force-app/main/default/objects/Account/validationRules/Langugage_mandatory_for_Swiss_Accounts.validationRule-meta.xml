<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Langugage_mandatory_for_Swiss_Accounts</fullName>
    <active>false</active>
    <description>You must select an &apos;Invoice Language (CH Only)&apos; for Swiss accounts.</description>
    <errorConditionFormula>(AND(
    ISPICKVAL(CV_Subsidiary__c, &apos;CH&apos;),
    ISPICKVAL(Invoice_Language_CH_Only__c, &apos;&apos;)
)) &amp;&amp; $Setup.rh2__PS_Settings__c.rh2__Run_Validation_Rule__c</errorConditionFormula>
    <errorMessage>You must select an &apos;Invoice Language (CH Only)&apos; for Swiss accounts.</errorMessage>
</ValidationRule>
