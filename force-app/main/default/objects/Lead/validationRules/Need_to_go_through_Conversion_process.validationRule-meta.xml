<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Need_to_go_through_Conversion_process</fullName>
    <active>true</active>
    <errorConditionFormula>(ISPICKVAL(Status, &quot;Converted_to_an_Account&quot;)
&amp;&amp;
NOT(IsConverted)
&amp;&amp;
ISCHANGED(Status)) &amp;&amp; $Setup.rh2__PS_Settings__c.rh2__Run_Validation_Rule__c</errorConditionFormula>
    <errorDisplayField>Status</errorDisplayField>
    <errorMessage>Sorry, you can&apos;t choose the &quot;Converted to an Account&quot; status manually, you need to go through the conversion process by clicking on the &quot;Convert&quot; button.</errorMessage>
</ValidationRule>
