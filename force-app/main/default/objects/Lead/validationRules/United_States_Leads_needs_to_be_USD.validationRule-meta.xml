<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>United_States_Leads_needs_to_be_USD</fullName>
    <active>true</active>
    <errorConditionFormula>((Country =&apos;United States&apos; &amp;&amp; NOT(ISPICKVAL(CurrencyIsoCode, &apos;USD&apos;)))
 &amp;&amp; 
 Event_Lead_Uploaded__c = TRUE) &amp;&amp; $Setup.rh2__PS_Settings__c.rh2__Run_Validation_Rule__c</errorConditionFormula>
    <errorDisplayField>CurrencyIsoCode</errorDisplayField>
    <errorMessage>Lead currency must be set to USD for US customers</errorMessage>
</ValidationRule>
