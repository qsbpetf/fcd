<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Campaign_allocation_inbound_lead_only</fullName>
    <active>false</active>
    <errorConditionFormula>((ISPICKVAL(Lead_Type__c, &quot;Prospecting&quot;)  || 
ISPICKVAL(Lead_Type__c, &quot;Physical Event&quot;)) 
 &amp;&amp; 
NOT(ISBLANK(TEXT(InboundCampaignAllocation__c )))) &amp;&amp; $Setup.rh2__PS_Settings__c.rh2__Run_Validation_Rule__c</errorConditionFormula>
    <errorMessage>Please do not select an inbound campaign allocation unless the &apos;Lead Type&apos; is from inbound.</errorMessage>
</ValidationRule>
